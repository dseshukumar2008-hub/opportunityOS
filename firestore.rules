rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // Teams collection
    match /teams/{teamId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.ownerId || request.auth.uid in resource.data.members);
    }

    match /team_requests/{requestId} {
      allow read, write: if isAuthed();
    }

    match /team_messages/{messageId} {
      allow read, write: if isAuthed();
    }

    match /messages/{msgId} {
      allow read, write: if isAuthed();
    }

    match /requests/{reqId} {
      allow read, write: if isAuthed();
    }

    match /users/{userId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
      
      match /projectRecommendations/{docId} {
        allow read, write: if isAuthed() && request.auth.uid == userId;
      }
      match /interviewSessions/{docId} {
        allow read, write: if isAuthed() && request.auth.uid == userId;
      }
    }

    match /user_settings/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    match /career_roadmaps/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    match /career_coach_chats/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    match /resume_history/{docId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /resumes/{resumeId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /resume_reviews/{docId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /skill_gap_analysis/{docId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /achievements/{docId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /goals/{docId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /analytics/{docId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /activities/{actId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /notifications/{notifId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /dashboard_stats/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    match /opportunities/{oppId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    match /pending_opportunities/{oppId} {
      allow read, write: if isAuthed();
    }

    match /saved_opportunities/{docId} {
      allow read, write: if isAuthed() && request.auth.uid == resource.data.uid;
      allow create: if isAuthed() && request.auth.uid == request.resource.data.uid;
    }

    match /applications/{appId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.uid || request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.userId);
    }

    match /recommendations/{recId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.uid);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.userId || request.auth.uid == request.resource.data.uid);
      allow update, delete: if isAuthed() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.uid);
    }

    match /connections/{connId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
      allow create: if isAuthed() && (request.auth.uid == request.resource.data.userId1 || request.auth.uid == request.resource.data.userId2);
      allow update: if false;
      allow delete: if isAuthed() && (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
    }

    match /connection_requests/{reqId} {
      allow read: if isAuthed() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create: if isAuthed() && request.auth.uid == request.resource.data.fromUserId;
      allow update: if isAuthed() && request.auth.uid == resource.data.toUserId;
      allow delete: if isAuthed() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
    }

    // Default deny for anything not matched above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
